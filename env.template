# OpenAI API Configuration
# Copy this file to .env and add your actual API key

# Required: Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for LLM features (default: gpt-4o-mini)
OPENAI_MODEL=gpt-5.2

# Optional: Application Settings
# DATABASE_URL is not required; default is sqlite:///data/app.db
LOG_LEVEL=INFO

# Instructions:
# 1. Copy this file: cp env.template .env
# 2. Get API key: https://platform.openai.com/api-keys
# 3. Replace 'sk-your-openai-api-key-here' with your actual key
# 4. Save the file
# 5. Start the backend: docker compose up -d backend
