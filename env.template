# OpenAI API Configuration
# Copy this file to .env and add your actual API key

# Required: Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Model Settings (defaults shown)
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1500

# Optional: Application Settings
# DATABASE_URL is not required; default is sqlite:///data/app.db (data/app.db)
LOG_LEVEL=INFO

# Instructions:
# 1. Copy this file: cp env.template .env
# 2. Get API key: https://platform.openai.com/api-keys
# 3. Replace 'sk-your-openai-api-key-here' with your actual key
# 4. Save the file
# 5. Run: python src/example_usage.py
